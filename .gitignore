node_modules/

# Secrets / session — never commit. Anchored to the repo root so these
# runtime dirs don't also swallow source dirs like packages/*/src/auth/.
/auth/
.env

# Crawled output (can be large; regenerate from a crawl)
/data/

# Downloaded attachments (via mizito_download_file)
/downloads/

# Generated SQLite database (rebuild with `npm run db`)
/db/*.db
/db/*.db-wal
/db/*.db-shm

# Playwright MCP scratch artifacts
.playwright-mcp/
*.tmp

# Build output (rebuild with `npm run build`)
packages/*/dist/

# Local Claude Code harness state
.claude/

# Local MCP client config (machine-specific absolute paths)
.mcp.json
