{
  "name": "@mohsp-99/mizito-bridge",
  "version": "0.1.0",
  "type": "module",
  "description": "Bridge your Mizito (office.mizito.ir) workspace to AI assistants and local tooling: an MCP server that reads your tasks/messages AND creates tasks, comments, and sends messages, plus a crawler, SQLite loader, and viewer. Logs in via a real browser, saves the session, and works through Mizito's (reverse-engineered) API.",
  "license": "MIT",
  "author": "mohsp-99",
  "homepage": "https://github.com/mohsp-99/mizito-bridge#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mohsp-99/mizito-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/mohsp-99/mizito-bridge/issues"
  },
  "keywords": [
    "mizito",
    "mcp",
    "model-context-protocol",
    "claude",
    "tasks",
    "project-management",
    "automation"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "mizito": "bin/mizito.mjs"
  },
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./core/*": "./core/*"
  },
  "files": [
    "bin/",
    "core/",
    "apps/",
    "docs/",
    "index.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "login": "node apps/crawler/login.mjs",
    "mcp": "node apps/mcp/index.mjs",
    "projects": "node apps/crawler/projects.mjs",
    "discover": "node apps/crawler/discover.mjs",
    "crawl": "node apps/crawler/crawl.mjs",
    "view": "node apps/viewer/server.mjs",
    "files": "node apps/crawler/download-files.mjs",
    "db": "node --no-warnings apps/crawler/load-db.mjs",
    "api": "node apps/crawler/api.mjs",
    "extract": "node apps/crawler/extract-api-surface.mjs",
    "test:write": "node apps/crawler/write-probe.mjs",
    "postinstall": "playwright install chromium || exit 0",
    "prepublishOnly": "node -e \"process.exit(0)\""
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "playwright": "^1.49.0",
    "zod": "^4.4.3"
  }
}
