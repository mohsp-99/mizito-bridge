{
  "name": "@mohsp-99/mizito",
  "version": "0.1.0",
  "type": "module",
  "description": "Typed client library for the Mizito (office.mizito.ir) API — tasks, chat, letters, projects, workspaces. Reverse-engineered, no browser, no server: log in with a saved session or credentials and call the API directly.",
  "license": "MIT",
  "author": "mohsp-99",
  "homepage": "https://github.com/mohsp-99/mizito-bridge#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mohsp-99/mizito-bridge.git",
    "directory": "packages/mizito"
  },
  "bugs": {
    "url": "https://github.com/mohsp-99/mizito-bridge/issues"
  },
  "keywords": [
    "mizito",
    "tasks",
    "project-management",
    "api-client",
    "typescript",
    "automation"
  ],
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run build",
    "test": "node --test",
    "prepack": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {}
}
