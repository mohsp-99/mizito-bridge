{
  "name": "mizito-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Monorepo for the Mizito (office.mizito.ir) bridge: @mohsp-99/mizito (core API library), @mohsp-99/mizito-crawler (browser login, crawler, SQLite, viewer), @mohsp-99/mizito-mcp (MCP server).",
  "license": "MIT",
  "author": "mohsp-99",
  "homepage": "https://github.com/mohsp-99/mizito-bridge#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mohsp-99/mizito-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/mohsp-99/mizito-bridge/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "mizito": "bin/mizito.mjs"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "login": "node packages/mizito-crawler/src/login.mjs",
    "relogin": "node packages/mizito-crawler/src/relogin.mjs",
    "mcp": "node packages/mizito-mcp/src/index.mjs",
    "projects": "node packages/mizito-crawler/src/projects.mjs",
    "discover": "node packages/mizito-crawler/src/discover.mjs",
    "crawl": "node packages/mizito-crawler/src/crawl.mjs",
    "view": "node packages/mizito-crawler/src/viewer/server.mjs",
    "files": "node packages/mizito-crawler/src/download-files.mjs",
    "db": "node --no-warnings packages/mizito-crawler/src/load-db.mjs",
    "api": "node packages/mizito-crawler/src/api.mjs",
    "extract": "node packages/mizito-crawler/src/extract-api-surface.mjs",
    "test:write": "node packages/mizito-crawler/src/write-probe.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
